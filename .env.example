# Database
DATABASE_URL=postgres://USER:PASSWORD@HOST:25060/DBNAME?sslmode=require
PGSSL=true

# API
PHANTASMA_API_PORT=3000
PHANTASMA_API_CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# RPC
PHANTASMA_RPC_URLS=https://pharpc1.phantasma.info/rpc,https://pharpc2.phantasma.info/rpc
PHANTASMA_RPC_ATTEMPTS=2
PHANTASMA_RPC_TIMEOUT_MS=6000
PHANTASMA_BLOCK_REQUEST_INTERVAL_MS=1000
PHANTASMA_METADATA_REQUEST_INTERVAL_MS=500

# Sync behavior
PHANTASMA_CAPTURE_RAW_EVENTS=true
PHANTASMA_SYNC_BLOCK_LOG_INTERVAL=100

# API paging/graph limits
PHANTASMA_GRAPH_MAX_EDGES_PER_REQUEST=1200
PHANTASMA_TX_PAGE_SIZE=50
PHANTASMA_TX_PAGE_SIZE_MAX=250
PHANTASMA_TOKEN_GRAPH_MAX_EDGES=5000
