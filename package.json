{
  "name": "create-maps",
  "version": "0.1.0",
  "private": true,
  "description": "Phantasma blockchain sync workers and API server",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "npm run api",
    "build": "node node_modules/esbuild/bin/esbuild apiServer.ts --bundle --platform=node --target=node22 --outfile=dist/apiServer.js --external:pg-native",
    "start:prod": "node dist/apiServer.js",
    "api": "tsx apiServer.ts",
    "backfill": "tsx backfill.ts",
    "backfill:dry-run": "tsx backfillDryRun.ts",
    "sync": "tsx syncIncremental.ts",
    "sync:nodes-normalized": "tsx syncNodeBalancesNormalized.ts",
    "find-first-transfer": "tsx findFirstTransferBlock.ts",
    "check": "tsc --noEmit",
    "test:rpc": "tsx connectPhantasma.ts",
    "test:db-snapshot": "tsx testDatabaseInserts.ts",
    "cleanup:claims": "tsx cleanupBlockClaims.ts"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "phantasma-sdk-ts": "^0.7.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
